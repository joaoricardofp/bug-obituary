# .env.example � copy to .env.local and fill in your values.
# Never commit .env.local.

# Groq API � get your free key at https://console.groq.com
GROQ_API_KEY=

# Upstash Redis — provisioned automatically on Upstash, copy from dashboard for local dev
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: set to "local" to use the JSON file fallback instead of KV in development
PERSISTENCE_DRIVER=
